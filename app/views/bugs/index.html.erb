<div class="container">
  <h1>🐞 Bug Generator</h1>
  <p>今日のあなたのバグ</p>

  <turbo-frame id="bug">
    <span class="bug-category"><%= @category %></span>

    <div class="error-box <%= 'rare' if @rare %>">
      <%= @bug %>
    </div>

    <% if @bug_count > 1 %>
      <p class="bug-counter">今日 <strong><%= @bug_count %></strong> 回バグった 🐞</p>
    <% end %>

    <div class="buttons"
         data-controller="copy"
         data-copy-text-value="<%= @bug %>">
      <%= button_to "もう一回バグる", root_path, method: :get, class: "bug-btn",
            data: { turbo_frame: "bug" } %>

      <button class="copy-btn" data-copy-target="btn" data-action="copy#copy">
        コピー
      </button>

      <a href="https://twitter.com/intent/tweet?text=<%= ERB::Util.url_encode(@share_text) %>&url=<%= ERB::Util.url_encode(@share_url) %>"
         target="_blank" rel="noopener" class="share-btn">
        ✕ 投稿
      </a>
    </div>
  </turbo-frame>
</div>
