<div class="container">
  <h1>🐞 Bug Generator</h1>
  <p>今日のあなたのバグ</p>

  <turbo-frame id="bug">
    <span class="bug-category"><%= @category %></span>

    <div class="error-box <%= 'rare' if @rare %>">
      <%= @bug %>
    </div>

    <% if @bug_count > 1 %>
      <p class="bug-counter">今日 <strong><%= @bug_count %></strong> 回バグった 🐞</p>
    <% end %>

    <div class="buttons"
         data-controller="copy"
         data-copy-text-value="<%= @bug %>">
      <%= button_to "もう一回バグる", root_path, method: :get, class: "bug-btn",
            data: { turbo_frame: "bug" } %>

      <button class="copy-btn" data-copy-target="btn" data-action="copy#copy">
        コピー
      </button>

      <a href="https://twitter.com/intent/tweet?text=<%= ERB::Util.url_encode(@share_text) %>&url=<%= ERB::Util.url_encode(@share_url) %>"
         target="_blank" rel="noopener" class="share-btn">
        ✕ 投稿
      </a>
    </div>
  </turbo-frame>

  <a href="https://github.com/mize1978/bug_generator" target="_blank" rel="noopener" class="github-link">
    <svg class="github-link-ico" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
    </svg>
    GitHub
  </a>
</div>
